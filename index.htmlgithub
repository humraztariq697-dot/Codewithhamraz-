<script>
function copyCode(btn) {
  const code = btn.nextElementSibling.querySelector('code').innerText;
  navigator.clipboard.writeText(code);
  btn.innerText = "Copied!";
  setTimeout(() => btn.innerText = "Copy", 2000);
}
</script>

